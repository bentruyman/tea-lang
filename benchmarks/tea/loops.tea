# Benchmark: Integer arithmetic in tight loops
# Tests basic arithmetic operations and loop performance

def sum_to_n(n: Int) -> Int
  var total = 0
  var i = 1

  while i <= n
    total = total + i
    i = i + 1
  end

  return total
end

var i = 0
var result = 0
const iterations = 20000000
const base_n = 1000

while i < iterations
  result = result + sum_to_n(base_n + i % 7)
  i = i + 1
end

print(result)
